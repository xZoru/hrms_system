{
    "php": {
        "extensions": [
            "gd",
            "mbstring",
            "pdo_pgsql",
            "pdo_mysql",
            "zip",
            "curl",
            "fileinfo",
            "json",
            "openssl"
        ]
    },
    "build": {
        "commands": {
            "pre-build": [
                "apt-get update && apt-get install -y libpng-dev libjpeg-dev libfreetype6-dev",
                "docker-php-ext-configure gd --with-freetype --with-jpeg",
                "docker-php-ext-install gd"
            ]
        }
    }
}